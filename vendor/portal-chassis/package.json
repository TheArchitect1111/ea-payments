      "types": "./dist/intent.d.ts",
      "import": "./dist/intent.js",
      "require": "./dist/intent.cjs"
    },
    "./opportunity-graph": {
      "types": "./dist/opportunity-graph.d.ts",
      "import": "./dist/opportunity-graph.js",
      "require": "./dist/opportunity-graph.cjs"
    },
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@clerk/nextjs": ">=5.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@clerk/nextjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@clerk/nextjs": "^6.12.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "^15.5.19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheArchitect1111/ea-operating-system.git",
    "directory": "portal-core"
  },
  "keywords": [
    "ea",
    "portal",
    "chassis",
    "nextjs",
    "airtable",
    "resend"
  ]
}
