      "types": "./dist/brief.d.ts",
      "import": "./dist/brief.js",
      "require": "./dist/brief.cjs"
    },
    "./brief-experience": {
      "types": "./dist/brief-experience.d.ts",
      "import": "./dist/brief-experience.js",
      "require": "./dist/brief-experience.cjs"
    },
    "./platform-events": {
      "types": "./dist/platform-events.d.ts",
      "import": "./dist/platform-events.js",
      "require": "./dist/platform-events.cjs"
