{
  "name": "@ea/portal-chassis",
  "version": "0.3.2",
  "description": "EA Portal Chassis — shared auth, layout, email, webhooks, and Airtable adapters for multi-tenant portals",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js",
      "require": "./dist/env.cjs"
    },
    "./hmac": {
      "types": "./dist/hmac.d.ts",
      "import": "./dist/hmac.js",
      "require": "./dist/hmac.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js",
      "require": "./dist/layout.cjs"
    },
    "./portal-layout": {
      "types": "./dist/portal-layout.d.ts",
      "import": "./dist/portal-layout.js",
      "require": "./dist/portal-layout.cjs"
    },
    "./clerk": {
      "types": "./dist/clerk.d.ts",
      "import": "./dist/clerk.js",
      "require": "./dist/clerk.cjs"
