      "require": "./dist/airtable.cjs"
    },
    "./email": {
      "types": "./dist/email.d.ts",
      "import": "./dist/email.js",
      "require": "./dist/email.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
