{
  "manifest_version": 3,
  "name": "EA Simplifi + Amplifi",
  "version": "3.0.0",
  "description": "Screenshot capture with Simplifi. Magnifi builds automatically. Amplifi shares the link. Background processing + notifications.",
  "permissions": ["activeTab", "contextMenus", "storage", "tabs", "notifications"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simplifi + Amplifi",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ea-payments.vercel.app/extension/connect*",
        "https://www.efficiencyarchitects.online/extension/connect*",
        "http://localhost:3000/extension/connect*"
      ],
      "js": ["connect-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://ea-payments.vercel.app/*",
        "https://www.efficiencyarchitects.online/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "ea-simplifi-amplifi@efficiencyarchitects.online",
      "strict_min_version": "109.0"
    }
  }
}
