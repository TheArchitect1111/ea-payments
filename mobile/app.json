{
  "expo": {
    "name": "Simplifi",
    "slug": "simplifi-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "simplifi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1B2B4D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "online.efficiencyarchitects.simplifi",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Simplifi to transcribe your voice into capture notes.",
        "NSMicrophoneUsageDescription": "Allow Simplifi to dictate notes for captures."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B2B4D"
      },
      "package": "online.efficiencyarchitects.simplifi",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Simplifi to analyze photos of opportunities.",
          "cameraPermission": "Allow Simplifi to capture photos of opportunities."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
