{
  "name": "simplifi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "node scripts/start-production.mjs",
    "start:next": "next start",
    "lint": "eslint",
    "test:tenant-safety": "node scripts/test-tenant-safety.mjs",
