  "dependencies": {
    "@clerk/nextjs": "^7.5.9",
    "@ea/capability-registry": "file:./vendor/capability-registry",
    "@ea/module-engine": "file:./vendor/module-engine",
    "@ea/portal-chassis": "file:./vendor/portal-chassis",
    "@ea/premium-chassis": "file:./vendor/premium-chassis",
    "@measured/puck": "^0.20.2",
    "@sentry/nextjs": "^10.59.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lenis": "^1.3.23",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.1",
    "@ea/theme-engine": "file:./vendor/theme-engine",
    "@ea/personality-engine": "file:./vendor/personality-engine",
    "@ea/website-engine": "file:./vendor/website-engine",
    "@ea/workspace-engine": "file:./vendor/workspace-engine",
    "@ea/payments-contract": "file:./vendor/payments-contract"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
