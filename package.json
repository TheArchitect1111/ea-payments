    "setup-pulse-events": "node scripts/setup-pulse-events-table.mjs",
    "verify-airtable": "node scripts/verify-airtable-schema.mjs",
    "verify:eacp": "node scripts/verify-eacp-readiness.mjs",
    "test:capture-e2e": "node scripts/test-capture-e2e.mjs",
    "test:connect-mvp": "node scripts/test-connect-mvp.mjs",
    "test:agents": "node scripts/test-agent-framework.mjs",
    "test:packages": "node scripts/test-productized-packages.mjs",
    "test:assessment-pathway": "node scripts/test-assessment-pathway.mjs",
    "test:tier2": "node scripts/test-tier2-launch.mjs",
    "launch:report": "node scripts/launch-command-center.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "launch:webhooks": "node scripts/verify-webhook-readiness.mjs",
    "launch:readiness": "node scripts/launch-readiness.mjs",
    "repo:readiness": "node scripts/repo-readiness.mjs",
    "ops:report": "node scripts/ops-report.mjs",
    "backup:verify": "node scripts/backup-verify.mjs",
    "chassis:tenant": "node scripts/create-tenant-package.mjs",
    "guide:owner": "node scripts/generate-owner-guide.mjs",
    "setup:launch-verification": "node scripts/create-stripe-launch-verification.mjs",
    "warm:admin": "node scripts/warm-admin-routes.mjs",
    "mobile:install": "cd mobile && npm install",
    "mobile:start": "cd mobile && npm start",
    "mobile:lint": "cd mobile && npm run lint"
