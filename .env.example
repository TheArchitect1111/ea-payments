# Partner Network (Efficiency Architects - Partner Network base)
AIRTABLE_PARTNER_NETWORK_BASE_ID=appnyHBarTuXIG9Ke
DEFAULT_COMMISSION_PERCENTAGE=0.20

# Admin + magic-link login signing (required for all sign-in)
ADMIN_SESSION_SECRET=your-64-char-hex-secret-here
ADMIN_PASSWORD=your-admin-password-here
# Airtable table for persistent admin users (recommended for production)
AIRTABLE_ADMIN_USERS_TABLE_ID=

# Clerk keys are no longer used for login (magic link is the single sign-in method).

# EA Capture Engine (Wave 2)
EA_CAPTURE_API_KEY=generate-a-long-random-secret-for-browser-extension
FIRECRAWL_API_KEY=fc-...
AIRTABLE_CAPTURES_TABLE=Capture Records
PULSE_EVENTS_TABLE=Pulse Events
