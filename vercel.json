{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "redirects": [
    {
      "source": "/ctp",
      "destination": "/ctp-intake",
      "permanent": false
    },
    {
      "source": "/discover",
      "destination": "/ctp-intake",
      "permanent": false
    },
    {
      "source": "/assessment",
      "destination": "/ctp-intake",
      "permanent": false
    },
    {
      "source": "/go",
      "destination": "/start",
      "permanent": false
    },
    {
      "source": "/partner-portal",
      "destination": "/partners/login",
      "permanent": true
    },
    {
      "source": "/partner-portal/:path*",
      "destination": "/partners/login",
      "permanent": true
    },
    {
      "source": "/capture",
      "destination": "/simplifi/capture",
      "permanent": false
    },
    {
      "source": "/amplify",
      "destination": "/amplifi",
      "permanent": false
    },
    {
      "source": "/story/:slug",
      "destination": "/consider/:slug",
      "permanent": false
    },
    {
      "source": "/sign-in",
      "destination": "/portal/login",
      "permanent": false
    },
    {
      "source": "/products/simplifi",
      "destination": "/simplifi/capture",
      "permanent": false
    },
    {
      "source": "/products/magnifi",
      "destination": "/story/selena",
      "permanent": false
    },
    {
      "source": "/products/amplifi",
      "destination": "/amplify",
      "permanent": false
    },
    {
      "source": "/products/pulse",
      "destination": "/sign-in?next=/portal/demo-client/pulse",
      "permanent": false
    },
    {
      "source": "/magnifi",
      "destination": "/story/selena",
      "permanent": false
    },
    {
      "source": "/amplifi/share",
      "destination": "/amplifi",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "/simplifi/workspace",
      "permanent": false
    },
    {
      "source": "/experience",
      "destination": "/possibilities",
      "permanent": true
    },
    {
      "source": "/what-is-ea",
      "destination": "/possibilities",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-EA-Platform",
          "value": "ea-platform"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/platform-guardian",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/connect-sequence",
      "schedule": "0 14 * * *"
    }
  ]
}
